# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials
# Create at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Data encryption key — generate with: openssl rand -base64 32
# Used to encrypt user progress data before storing in Redis
DATA_ENCRYPTION_KEY=

# Upstash Redis credentials
# Create a free database at https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
